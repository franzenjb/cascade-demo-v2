# ─────────────────────────────────────────────────────────────
# Cascade Demo V2 — Environment Variables
# Copy to .env.local and fill in. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ─── Anthropic / Claude ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
CLAUDE_MODEL=claude-sonnet-4-6

# ─── Supabase (public tables: SVI, NRI, ALICE, FEMA) ─────────
# V2 reuses the ops.jbf.com Supabase for public datasets. Swap
# to a dedicated instance later if V2 needs its own quota.
SUPABASE_URL=https://qoskpyfgimjcmmxunfji.supabase.co
SUPABASE_ANON_KEY=

# ─── Parcel API (Florida) ────────────────────────────────────
# Reused from ops.jbf.com; Dragon's own Railway deploy.
PARCEL_API_URL=https://florida-parcels-production-fd39.up.railway.app

# ─── County / scenario focus ─────────────────────────────────
# Hillsborough County, FL (FIPS 12057)
NEXT_PUBLIC_STATE_ABBR=FL
NEXT_PUBLIC_COUNTY_FIPS=12057
NEXT_PUBLIC_COUNTY_NAME=Hillsborough
NEXT_PUBLIC_MAP_CENTER_LNG=-82.4572
NEXT_PUBLIC_MAP_CENTER_LAT=27.9506
NEXT_PUBLIC_MAP_ZOOM=9

# ─── Demo mode ───────────────────────────────────────────────
# off     — always call Anthropic API (default for V2)
# replay  — replay saved transcripts if available
# live    — call API + save transcript
DEMO_MODE=off
